# ==============================================================
# Beaverdash - Environment Variables Template
# ==============================================================
# Sao chép file này thành .env và điền giá trị thực của bạn vào.
# KHÔNG commit file .env lên Git!
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to Git!
# ==============================================================

# --- Identity Service ---
IDENTITY_DB_CONNECTION=Host=localhost;Port=5432;Database=beaverdash_identity_db;Username=postgres;Password=YOUR_DB_PASSWORD

# --- Project Management Service ---
PM_DB_CONNECTION=Host=localhost;Port=5432;Database=beaverdash_pm_db;Username=postgres;Password=YOUR_DB_PASSWORD

# --- JWT (shared across services) ---
JWT_SECRET=YOUR_SUPER_SECRET_JWT_KEY_MIN_32_CHARS

# --- PostgreSQL (Docker) ---
POSTGRES_PASSWORD=YOUR_DB_PASSWORD

# --- RabbitMQ (Docker) ---
RABBITMQ_USER=YOUR_RABBITMQ_USER
RABBITMQ_PASS=YOUR_RABBITMQ_PASS

# --- AI Assistant Service ---
ASSISTANT_DB_CONNECTION=postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/beaverdash_ai_assistant_db
GEMINI_API_KEY=YOUR_GEMINI_API_KEY  # Used for LLM Task/Subtask suggestions
GROQ_API_KEY=YOUR_GROQ_API_KEY
GITHUB_MODEL_TOKEN=YOUR_GITHUB_MODEL_TOKEN
PM_SERVICE_BASE_URL=http://localhost:5002

# --- Email Notification (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR_EMAIL@gmail.com
SMTP_PASSWORD=YOUR_APP_PASSWORD
SMTP_SENDER_NAME=Beaverdash
SMTP_SENDER_EMAIL=YOUR_EMAIL@gmail.com

# --- Email Logo (Public URL for email templates) ---
EMAIL_LOGO_URL=https://your-cdn-or-hosting.com/beaverdash-logo.png

# --- Frontend ---
FRONTEND_BASE_URL=http://localhost:3000
